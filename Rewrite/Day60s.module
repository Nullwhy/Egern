# 每日60S — Egern 模块
# 作者: @Nullwhy
# 更新: 2026-07-23
name: "每日60S"
description: "每天定时推送60秒新闻"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/MoeGirlWiki.png"

compat_arguments:
  MINUTE: "15"
  HOUR: "8"
  MAX_NEWS: "5"
  MULTI_NOTIFY: "false"
  CHUNK_SIZE: "5"
  OPEN_URL: "image"
  ALLOW_REPEAT: "false"

env_schema:
  MINUTE:
    name: 分钟
    description: 每天触发的分钟（0-59），默认 15
    default_value: "15"
  HOUR:
    name: 小时
    description: 每天触发的小时（0-23），默认 8
    default_value: "8"
  MAX_NEWS:
    name: 新闻条数
    description: 单条默认 5；0=全部。开启多条通知时自动用全部新闻拆分
    default_value: "5"
  MULTI_NOTIFY:
    name: 多条通知
    description: 开启后按「每条通知条数」拆分；默认关闭
    default_value: "false"
    options:
      - "false"
      - "true"
  CHUNK_SIZE:
    name: 每条通知条数
    description: 仅多条通知开启时生效，默认 5
    default_value: "5"
  OPEN_URL:
    name: 点击通知
    description: none=不跳转 / image=打开海报
    default_value: "image"
    options:
      - image
      - none
  ALLOW_REPEAT:
    name: 推送
    description: 默认关闭（同日只推送一次）/开启后同日可推送多次
    default_value: "false"
    options:
      - "false"
      - "true"

scriptings:
  - schedule:
      name: "每日60S"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/Day60s.js"
      env:
        MAX_NEWS: "{{{MAX_NEWS}}}"
        MULTI_NOTIFY: "{{{MULTI_NOTIFY}}}"
        CHUNK_SIZE: "{{{CHUNK_SIZE}}}"
        OPEN_URL: "{{{OPEN_URL}}}"
        ALLOW_REPEAT: "{{{ALLOW_REPEAT}}}"
