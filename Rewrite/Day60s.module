# 每日60S — Egern 模块
# 格式: Egern 原生模块（YAML 内容，扩展名 .module）
# 作者: @Nullwhy
# 更新: 2026-07-23
name: "每日60S"
description: "每天定时推送60秒新闻"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/MoeGirlWiki.png"

compat_arguments:
  MINUTE: "15"
  HOUR: "8"
  MAX_NEWS: "0"
  OPEN_URL: "none"
  DEDUPE: "false"
env_schema:
  MINUTE:
    name: 分钟
    description: 每天触发的分钟（0-59），默认 15
    default_value: "15"
  HOUR:
    name: 小时
    description: 每天触发的小时（0-23），默认 8（即 08:15）
    default_value: "8"
  MAX_NEWS:
    name: 新闻条数
    description: 默认0=全部新闻（通知内阅读）；>0 为前N条
    default_value: "0"
  OPEN_URL:
    name: 点击打开
    description: none=不跳转（推荐，少开 Egern） / image=打开海报
    options:
      - none
      - image
  DEDUPE:
    name: 同日只推一次
    description: 默认关闭
    options:
      - "true"
      - "false"

scriptings:
  - schedule:
      name: "每日60S"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/Day60s.js"
      env:
        MAX_NEWS: "{{{MAX_NEWS}}}"
        OPEN_URL: "{{{OPEN_URL}}}"
        DEDUPE: "{{{DEDUPE}}}"
