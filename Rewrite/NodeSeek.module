# NodeSeek — Egern 模块
#
# 自定义时间：改 Template Arguments 的 MINUTE + HOUR（两处若有表单请填一致）
# 例 9:08 → MINUTE=08  HOUR=9
# 分钟用两位 00/08/30，不要只写 0
# 改完 Save；脚本「NodeSeek 签到」里 cron 应变成「分 时 * * *」
# 保持 VPN 开启。已取消每分钟轮询。
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "00"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

compat_arguments_desc: |
  签到时间：Template Arguments 中 MINUTE（分）与 HOUR（时）须与设置框一致。
  例 9:08 → MINUTE=08，HOUR=9；10:00 → MINUTE=00，HOUR=10。
  改完 Done → Save。到脚本详情确认 cron 为「分 时 * * *」。

env_schema:
  MINUTE:
    name: 分钟
    description: 建议两位 00-59。例 9:08 填 08
    default_value: "00"
  HOUR:
    name: 小时
    description: 0-23。例 9:08 填 9。须与 Template Arguments 一致
    default_value: "10"
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  # 每天只触发一次：分 时 日 月 周（不再每分钟轮询）
  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
