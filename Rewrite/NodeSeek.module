# NodeSeek — Cookie 捕获 + 定时签到
# 时间只改 Template Arguments：MINUTE / HOUR
name: "NodeSeek"
description: "每天定时自动签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "00"
  HOUR: "10"
  ENABLE_CAPTURE: "false"
  FIXED_LEGS: "false"

compat_arguments_desc: |
  MINUTE=分
  HOUR=时
  ENABLE_CAPTURE=Cookie 捕获（true 开 / false 关）
  FIXED_LEGS=固定鸡腿（false=随机 / true=固定5）

# Cookie / 固定鸡腿；时间不进 env_schema
env_schema:
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"
  FIXED_LEGS:
    name: 固定鸡腿
    description: 关闭=随机鸡腿；开启=固定 5 鸡腿
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      env:
        MODE: "checkin"
        FIXED_LEGS: "{{{FIXED_LEGS}}}"
