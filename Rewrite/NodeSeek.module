# NodeSeek — Egern 模块
# 手动可签到、定时不跑时：已改为 6 字段 cron（秒 分 时 日 月 周）
# 1. Cookie 开 → 个人页 → 关 Cookie
# 2. 到点签到；也可手动跑「NodeSeek 签到」
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "0"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

env_schema:
  MINUTE:
    name: 分钟
    description: 0-59，默认 0。改完请 Save
    default_value: "0"
  HOUR:
    name: 小时
    description: 0-23，默认 10。改完请 Save
    default_value: "10"
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  # 6 字段：秒 分 时 日 月 周（部分 Egern 版本对 schedule 更稳）
  - schedule:
      name: "NodeSeek 签到"
      cron: "0 {{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      env:
        ENABLE_CAPTURE: "false"
        MODE: "checkin"

  # 手动入口（不依赖 cron）
  - generic:
      name: "NodeSeek 手动签到"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      env:
        ENABLE_CAPTURE: "false"
        MODE: "checkin"
