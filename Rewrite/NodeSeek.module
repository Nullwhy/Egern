# NodeSeek — Egern 模块
#
# 【自定义定时 — 必读】
# 真正生效的是 Template Arguments（模板参数）里的 MINUTE / HOUR。
# 请点「Edit Template Argument」修改，再 Save。
# 不要只改其它输入框（可能不同步，仍跑默认 10:00）。
#
# 写法（与 Day60s 相同，5 段：分 时 日 月 周）：
#   分钟 MINUTE：建议两位 00/05/08/30（不要只写 0）
#   小时 HOUR：0-23
# 例：9:08 → MINUTE=08  HOUR=9
#     10:00 → MINUTE=00  HOUR=10
#     10:55 → MINUTE=55  HOUR=10
#
# 改完后请到 脚本 →「NodeSeek 签到」确认 cron 已是数字（如 55 10 * * *）
# 保持 Egern VPN 开启（可退后台，勿杀进程）
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "00"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

compat_arguments_desc: |
  自定义签到时间：只改本页 Template Arguments 的 MINUTE（分）和 HOUR（时）。
  例 9:08 → MINUTE=08，HOUR=9；10:00 → MINUTE=00，HOUR=10。
  改完 Done → Save。再到脚本「NodeSeek 签到」核对 cron 是否变成「分 时 * * *」。

# 时间只放在 compat_arguments，避免 env_schema 再生成一套不同步的输入框
env_schema:
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  - schedule:
      name: "NodeSeek 签到"
      # 分 时 日 月 周 —— 值来自 Template Arguments 的 MINUTE / HOUR
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
