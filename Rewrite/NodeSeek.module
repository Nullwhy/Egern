# NodeSeek — Egern 模块
# 自定义定时：改「小时」「分钟」（与 Day60s 相同，5 段 cron）
# 例：9:08 → 分钟 08、小时 9    10:00 → 分钟 00、小时 10
# 分钟请用两位（00/05/08），不要只写 0
# 改完必须 Save；保持 Egern VPN 开启（可退后台）
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "00"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

env_schema:
  MINUTE:
    name: 分钟
    description: "0-59，建议两位：00、08、30。例 9:08 填 08"
    default_value: "00"
  HOUR:
    name: 小时
    description: "0-23。例 9:08 填 9；10:00 填 10。改完 Save"
    default_value: "10"
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  # 自定义：分 时 日 月 周（与 Day60s 相同写法）
  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
