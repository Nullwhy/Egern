# NodeSeek — Egern 模块
#
# 【定时说明】
# 不使用 {{{CRON}}} 参数替换（你这边改了 Template Arguments 仍不触发）。
# 签到时间写死在下面 schedule.cron（与主配置直接写 cron 相同）。
# 默认：每天 10:00 → 0 10 * * *
# 若要 9:08：把 cron 改成 8 9 * * * 后更新模块（或改仓库后点模块更新）。
# 手动能签 = Cookie/脚本正常；到点需 Egern VPN 保持开启。
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  ENABLE_CAPTURE: "false"

env_schema:
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  # 写死 cron，不做模板替换（避免参数界面与真实 schedule 不一致）
  # 分 时 日 月 周 —— 改时间请改这一行后更新模块
  - schedule:
      name: "NodeSeek 签到"
      cron: "0 10 * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"

  - generic:
      name: "NodeSeek 手动签到"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
