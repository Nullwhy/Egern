# NodeSeek — Egern 模块
#
# 【自定义时间 — 方式B 修复版】
# Egern 模块对 schedule.cron 的 {{{参数}}} 在你设备上不可靠。
# 现改为：
#   1) schedule 每分钟触发一次（写死 cron: 0-59 每分）
#   2) 脚本读取 env.HOUR / env.MINUTE，到点才真正签到
# 请改 Template Arguments 的 HOUR、MINUTE 后 Save。
# 例：9:08 → HOUR=9  MINUTE=08
# 须保持 VPN 开启；手动签到请用「NodeSeek 手动签到」（FORCE=true）
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "00"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

compat_arguments_desc: |
  签到时间：修改 Template Arguments 的 HOUR（时）和 MINUTE（分）。
  例 9:08 → HOUR=9，MINUTE=08；10:00 → HOUR=10，MINUTE=00。
  分钟建议两位。改完 Done → Save。保持 VPN 开启。

env_schema:
  MINUTE:
    name: 分钟
    description: 签到分钟 00-59（建议两位）
    default_value: "00"
  HOUR:
    name: 小时
    description: 签到小时 0-23
    default_value: "10"
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  # 每分钟唤醒；是否签到由脚本按 HOUR/MINUTE 判断
  - schedule:
      name: "NodeSeek 签到"
      cron: "* * * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
      env:
        HOUR: "{{{HOUR}}}"
        MINUTE: "{{{MINUTE}}}"

  - generic:
      name: "NodeSeek 手动签到"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
      env:
        FORCE: "true"
