# NodeSeek — Egern 模块
# 定时签到使用独立脚本 Scripts/NodeSeek.CheckIn.js（与 Cookie 抓包分离，避免 schedule 不触发）
# 需保持 Egern VPN 连接（不必打开界面）
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "0"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

env_schema:
  MINUTE:
    name: 分钟
    description: 0-59，默认 0。改完请 Save 并确保 VPN 开启
    default_value: "0"
  HOUR:
    name: 小时
    description: 0-23，默认 10。改完请 Save 并确保 VPN 开启
    default_value: "10"
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  # 独立签到脚本，避免与 http_response 共用入口导致 cron 不注册
  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"

  - generic:
      name: "NodeSeek 手动签到"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
