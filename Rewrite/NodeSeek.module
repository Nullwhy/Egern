# NodeSeek — Egern 模块
#
# 签到时间：只在 Template Arguments 里改 MINUTE / HOUR（不要再用外面的时间输入框）
# 例：9:08 → MINUTE=08  HOUR=9
#     10:00 → MINUTE=00  HOUR=10
# 分钟建议两位 00/05/08；改完 Done → Save
# 到 脚本→NodeSeek 签到 确认 cron 为「分 时 * * *」
# 保持 VPN 开启
#
# 脚本：Scripts/NodeSeek.js 单文件（Cookie 捕获 + 签到）
name: "NodeSeek"
description: "每天定时自动签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  MINUTE: "00"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

compat_arguments_desc: |
  MINUTE=分
  HOUR=时
  ENABLE_CAPTURE=Cookie 捕获（true 开 / false 关）

# 仅保留 Cookie 开关；时间不放 env_schema，避免再生成「设定 cron」输入框
env_schema:
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      env:
        MODE: "checkin"
