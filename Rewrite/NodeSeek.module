# NodeSeek — Egern 模块
# 改定时：必须改「Template Arguments / 模板参数」里的 CRON，然后 Save
# 只改外面输入框、不同步到 Template Arguments 时，实际仍是默认 0 10 * * *
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  # 实际生效的 cron（分 时 日 月 周）。请在模块 Template Arguments 里修改 CRON
  CRON: "0 10 * * *"
  ENABLE_CAPTURE: "false"

compat_arguments_desc: |
  【定时必看】
  请点「Edit Template Argument / 编辑模板参数」修改 CRON，再点 Save。
  格式：分 时 日 月 周（5段，空格分隔）
  例：9:08 → 8 9 * * *
      10:00 → 0 10 * * *
      10:55 → 55 10 * * *
  改完后到脚本「NodeSeek 签到」详情确认 cron 已变成数字，不是 {{{CRON}}}。
  Cookie：默认关；开启后访问个人页保存请求头，成功后请关闭。

env_schema:
  CRON:
    name: 定时 CRON
    description: "务必同步到 Template Arguments。5段：分 时 日 月 周。例 55 10 * * * = 每天10:55"
    default_value: "0 10 * * *"
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{CRON}}}"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"

  - generic:
      name: "NodeSeek 手动签到"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
