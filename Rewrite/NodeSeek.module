# NodeSeek 每日签到 — Egern 模块
# 作者: @Nullwhy（脚本适配自 @Curtinp118）
# 更新: 2026-07-23
#
# 使用步骤：
# 1. 安装并启用本模块，确保 MITM 证书已信任
# 2. 打开「抓包」开关 → 登录 NodeSeek 访问个人相关页面
# 3. 收到「抓包成功」后，手动关闭「抓包」
# 4. 定时任务自动签到；也可手动运行「NodeSeek 签到」
name: "NodeSeek"
description: "NodeSeek 每日签到（先抓包再定时签到）"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/sooyaaabo/Loon/main/Icon/App-Icon/NodeSeek.png"

compat_arguments:
  MINUTE: "0"
  HOUR: "10"
  ENABLE_CAPTURE: "false"

env_schema:
  MINUTE:
    name: 分钟
    description: 每天签到的分钟（0-59），默认 0
    default_value: "0"
  HOUR:
    name: 小时
    description: 每天签到的小时（0-23），默认 10
    default_value: "10"
  ENABLE_CAPTURE:
    name: 抓包
    description: 默认关闭；开启后访问个人页保存请求头，成功后请手动关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek 抓包"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{MINUTE}}} {{{HOUR}}} * * *"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
