# NodeSeek — Egern 模块
# 定时：使用完整 CRON 字符串（分 时 日 月 周），避免 MINUTE=0 被替换成空
# 例：9:08 → 8 9 * * *    10:00 → 0 10 * * *    10:30 → 30 10 * * *
# 须保持 Egern VPN 开启（可退后台；杀进程则不会跑）
name: "NodeSeek"
description: "NS 每日定时签到"
author: "Nullwhy"
icon: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Icon/Nullwhy.png"

compat_arguments:
  # 完整 5 段 cron，默认每天 10:00
  CRON: "0 10 * * *"
  ENABLE_CAPTURE: "false"

env_schema:
  CRON:
    name: 定时 CRON
    description: "5段：分 时 日 月 周。例 9:08 填 8 9 * * * ；10:00 填 0 10 * * *。改完 Save"
    default_value: "0 10 * * *"
  ENABLE_CAPTURE:
    name: Cookie
    description: 默认关闭；开启后访问个人页保存 Cookie，成功后请关闭
    default_value: "false"
    options:
      - "false"
      - "true"

mitm:
  hostnames:
    - www.nodeseek.com

scriptings:
  - http_response:
      name: "NodeSeek Cookie"
      match: "^https://www\\.nodeseek\\.com/api/account/getInfo/"
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.js"
      body_required: false
      timeout: 30
      max_size: 1048576
      env:
        ENABLE_CAPTURE: "{{{ENABLE_CAPTURE}}}"

  - schedule:
      name: "NodeSeek 签到"
      cron: "{{{CRON}}}"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"

  - generic:
      name: "NodeSeek 手动签到"
      timeout: 60
      script_url: "https://raw.githubusercontent.com/Nullwhy/Egern/main/Scripts/NodeSeek.CheckIn.js"
